\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerfontthemejamcy}[2026/06/07 Jamcy font theme]

\mode<presentation>

\usefonttheme{professionalfonts}

\setbeamerfont{title}{series=\bfseries,size=\LARGE}
\setbeamerfont{subtitle}{series=\mdseries,size=\large}
\setbeamerfont{author}{size=\normalsize}
\setbeamerfont{date}{size=\small}

\setbeamerfont{frametitle}{series=\bfseries,size=\Large}
\setbeamerfont{framesubtitle}{series=\mdseries,size=\normalsize}

\setbeamerfont{block title}{series=\bfseries,size=\normalsize}
\setbeamerfont{block body}{size=\normalsize}

\setbeamerfont{author in head/foot}{size=\scriptsize}
\setbeamerfont{date in head/foot}{size=\scriptsize}

\mode<all>
