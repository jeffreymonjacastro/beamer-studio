\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemejamcy}[2026/06/07 Jamcy color theme]

\mode<presentation>

\definecolor{jamcyInk}{HTML}{17202A}
\definecolor{jamcyMuted}{HTML}{5D6D7E}
\definecolor{jamcyCanvas}{HTML}{F7F9FB}
\definecolor{jamcyPanel}{HTML}{FFFFFF}
\definecolor{jamcyAccent}{HTML}{1F7A8C}
\definecolor{jamcyAccentDark}{HTML}{0B4F6C}
\definecolor{jamcyWarm}{HTML}{C47F2D}
\definecolor{jamcyRule}{HTML}{D8DEE6}

\setbeamercolor{normal text}{fg=jamcyInk,bg=jamcyCanvas}
\setbeamercolor{structure}{fg=jamcyAccentDark}
\setbeamercolor{alerted text}{fg=jamcyWarm}

\setbeamercolor{title}{fg=jamcyInk}
\setbeamercolor{subtitle}{fg=jamcyMuted}
\setbeamercolor{author}{fg=jamcyMuted}
\setbeamercolor{date}{fg=jamcyMuted}

\setbeamercolor{frametitle}{fg=jamcyInk,bg=jamcyCanvas}
\setbeamercolor{framesubtitle}{fg=jamcyMuted}

\setbeamercolor{block title}{fg=jamcyPanel,bg=jamcyAccentDark}
\setbeamercolor{block body}{fg=jamcyInk,bg=jamcyPanel}
\setbeamercolor{block title alerted}{fg=jamcyPanel,bg=jamcyWarm}
\setbeamercolor{block body alerted}{fg=jamcyInk,bg=jamcyPanel}
\setbeamercolor{block title example}{fg=jamcyPanel,bg=jamcyAccent}
\setbeamercolor{block body example}{fg=jamcyInk,bg=jamcyPanel}

\setbeamercolor{itemize item}{fg=jamcyAccent}
\setbeamercolor{itemize subitem}{fg=jamcyWarm}
\setbeamercolor{enumerate item}{fg=jamcyAccentDark}

\setbeamercolor{author in head/foot}{fg=jamcyMuted,bg=jamcyCanvas}
\setbeamercolor{date in head/foot}{fg=jamcyMuted,bg=jamcyCanvas}

\mode<all>
